
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read and write access to settings (including the playlists document)
    match /settings/{document=**} {
      allow read, write: if true;
    }

    // Allow public read and write for channel visibility
    match /channel_visibility/{document=**} {
      allow read, write: if true;
    }

    // Allow public read and write for homepage content (hero slides and services)
    match /hero_slides/{document=**} {
      allow read, write: if true;
    }

    match /services/{document=**} {
      allow read, write: if true;
    }

    // Maintain backward compatibility for the playlists collection if still in use during transition
    match /playlists/{document=**} {
      allow read, write: if true;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
