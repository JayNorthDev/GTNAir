
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read and write access to settings for playlist URL
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Allow public read and write for channel visibility
    match /channel_visibility/{channelId} {
      allow read, write: if true;
    }

    // Allow public read and write for homepage content
    match /hero_slides/{slideId} {
      allow read, write: if true;
    }

    // Allow public read and write for services content
    match /services/{serviceId} {
      allow read, write: if true;
    }

    // Allow public read and write for the new playlists collection
    match /playlists/{playlistId} {
      allow read, write: if true;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
