
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to settings for playlist URL
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true; // Allow admins to update the URL. Should be secured.
    }

    // Allow admins to manage channel visibility
    match /channel_visibility/{channelId} {
      allow read: if true; // Front-end needs to read this
      allow write: if true; // Admin needs to write this. Should be secured.
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
